{
  "name": "code-coverage-summary",
  "version": "2.0.0",
  "description": "A GitHub Action that reads Cobertura format code coverage files and outputs a text or markdown summary.",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --conditions=require,import --outfile=dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/glob": "^0.6.1",
    "fast-xml-parser": "^5.5.7"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.3",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@actions/http-client": "^4.0.0"
  }
}
